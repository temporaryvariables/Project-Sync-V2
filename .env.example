# Shared Postgres connection (used by ground-station-api and flight-director-api)
POSTGRES_USER=mission
POSTGRES_PASSWORD=mission_secret
POSTGRES_DB=projectsync
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mission:mission_secret@postgres:5432/projectsync

# PocketBase (auth). Backends call this to validate Bearer tokens.
POCKETBASE_URL=http://pocketbase:8090

# Service ports
GROUND_STATION_PORT=3001
FLIGHT_DIRECTOR_PORT=3002
DEEP_SPACE_NETWORK_PORT=3003
ROVER_RELAY_PORT=4000

# Internal service URLs (used by deep-space-network and frontend build)
GROUND_STATION_URL=http://ground-station-api:3001

# Frontend build time variables (Vite). For local docker these point at host ports.
VITE_POCKETBASE_URL=http://localhost:8090
VITE_GROUND_STATION_URL=http://localhost:3001
VITE_FLIGHT_DIRECTOR_URL=http://localhost:3002
VITE_DEEP_SPACE_NETWORK_URL=http://localhost:3003
